# Garmin credentials
GARMIN_EMAIL=your-email@example.com
GARMIN_PASSWORD=your-password

# Webhook destination (where to POST synced data)
WEBHOOK_URL=https://your-server.com
WEBHOOK_API_KEY=your-api-key

# Optional — defaults are fine for most setups.
# NOTE: Use absolute paths, not ~ (tilde is not expanded in systemd).
# BROWSER_DATA_DIR=/home/youruser/.garmin-sync/browser-data
# LOG_DIR=/home/youruser/.garmin-sync/logs

# Pages to sync (comma-separated).
# Available: activities, body-composition, daily, personal-records, sleep, training-status
# Default: all pages. Override via CLI --pages or this env var.
# SYNC_PAGES=daily,sleep

# How long (ms) to wait for networkidle after each page loads.
# Garmin's SPA never reaches true idle, so this is a best-effort wait for API
# responses to arrive. Increase on slow connections; 5000 is fine for most setups.
# NETWORK_IDLE_TIMEOUT_MS=5000
